FROM node:24-bookworm-slim AS web-build

WORKDIR /app

COPY package.json pnpm-lock.yaml* ./
RUN corepack enable && pnpm install --frozen-lockfile

COPY tsconfig.json vite.config.ts ./
COPY web ./web
COPY src ./src

RUN pnpm run build:web

FROM denoland/deno:2.7.7

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates tar build-essential pkg-config libssl-dev \
  && arch="$(dpkg --print-architecture)" \
  && case "$arch" in \
    amd64) unpdf_asset="unpdf-linux-x86_64-v0.2.4.tar.gz" ;; \
    arm64) unpdf_asset="" ;; \
    *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; \
  esac \
  && if [ -n "$unpdf_asset" ]; then \
       curl -fsSL "https://github.com/iyulab/unpdf/releases/download/v0.2.4/${unpdf_asset}" -o /tmp/unpdf.tar.gz \
       && tar -xzf /tmp/unpdf.tar.gz -C /usr/local/bin unpdf \
       && chmod +x /usr/local/bin/unpdf \
       && rm -f /tmp/unpdf.tar.gz; \
     else \
       curl https://sh.rustup.rs -sSf | sh -s -- -y --profile minimal \
       && . "$HOME/.cargo/env" \
       && cargo install --git https://github.com/iyulab/unpdf --tag v0.2.4 unpdf-cli \
       && cp "$HOME/.cargo/bin/unpdf" /usr/local/bin/unpdf; \
     fi \
  && rm -rf /var/lib/apt/lists/*

COPY deno.json ./
COPY package.json ./
COPY quickwit ./quickwit
COPY src ./src
COPY web ./web
COPY --from=web-build /app/node_modules ./node_modules
COPY --from=web-build /app/web/dist ./web/dist

CMD ["run", "-A", "web/server.ts"]
