beta.openbesluitvorming.nl, openbesluitvorming.nl {
  @admin {
    path /admin /admin.html /api/admin/*
  }

  basic_auth @admin {
    admin {$ADMIN_PASSWORD_HASH}
  }

  encode gzip zstd

  # Expose only Quickwit's search endpoint publicly. Everything else under
  # /api/v1 (ingest, delete-tasks, index management) stays internal — the old
  # exclusion list missed /api/v1/*/delete-tasks.
  @quickwit {
    path /api/v1/*/search /api/v1/*/search/*
    method GET POST
  }
  reverse_proxy @quickwit quickwit:7280

  reverse_proxy openbesluitvorming:8787
}
