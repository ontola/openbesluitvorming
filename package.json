{
  "name": "woozi",
  "private": true,
  "type": "module",
  "scripts": {
    "web": "deno run -A web/server.ts",
    "test": "deno test -A",
    "test:e2e": "deno test -A tests/notubiz.test.ts",
    "test:quickwit": "deno test -A tests/quickwit.test.ts",
    "test:gui": "deno test -A tests/gui_e2e.test.ts",
    "extract:haarlem": "deno run -A src/main.ts haarlem 2025-01-14 2025-01-15",
    "ingest:haarlem": "deno run -A src/main.ts --quickwit haarlem 2025-01-14 2025-01-15",
    "lint": "oxlint src tests web",
    "format": "oxfmt --write src tests web",
    "check-format": "oxfmt --check src tests web"
  },
  "devDependencies": {
    "happy-dom": "^20.8.9",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0"
  }
}
